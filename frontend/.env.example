# Copy to `.env` (project root, next to vite.config.js) and adjust for your environment.

# API base URL the frontend will call (no trailing slash).
# Local dev:
#   VITE_API_URL=http://localhost:5000
# Production (Render Blueprint deploys to *.onrender.com by default):
#   VITE_API_URL=https://portfolio-contact-api.onrender.com
# Railway / Fly.io / custom domain:
#   VITE_API_URL=https://your-api.example.com
VITE_API_URL=http://localhost:5000
